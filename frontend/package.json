{
  "name": "plc-mc-frontend",
  "version": "1.0.0",
  "description": "Electron + React frontend for PLC Machine Control",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build",
    "preview": "vite preview"
  },
  "keywords": ["electron", "react", "plc"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^27.1.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}

